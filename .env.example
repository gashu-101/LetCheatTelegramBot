# --- Required -----------------------------------------------------------
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --- Behaviour ----------------------------------------------------------
# Comma-separated Telegram chat IDs. Leave EMPTY to allow every group.
ALLOWED_GROUPS=
# Telegram user id allowed to run /stats /groups /enable /disable /restart.
ADMIN_ID=
# Gemini model to use. gemini-2.5-flash is fastest; -pro is more accurate.
MODEL=gemini-2.5-flash

# --- Tunables (all optional) -------------------------------------------
MAX_CONCURRENCY=8
REQUEST_TIMEOUT_S=60
MAX_RETRIES=4
DEDUP_CACHE_SIZE=512
MAX_PDF_PAGES=10
LOG_LEVEL=INFO
# Leave empty for stdout only.
LOG_FILE=
